config BR2_PACKAGE_CONFIGTXT
	bool "configtxt"
	help
	  Configure Raspberry Pi boot settings: I2C, SPI, audio overlays.
	depends on BR2_PACKAGE_RPI_FIRMWARE

config BR2_PACKAGE_CONFIGTXT_QUIET
	bool "quiet boot mode"
	help
	  Disable all boot messages to screen.
	depends on BR2_PACKAGE_CONFIGTXT

config BR2_PACKAGE_CONFIGTXT_EEPROM
	bool "force_eeprom_read workaround"
	help
	  Set force_eeprom_read=0 for boards without HAT EEPROM.
	depends on BR2_PACKAGE_CONFIGTXT

config BR2_PACKAGE_CONFIGTXT_DAC_OVERLAY
	string "I2S DAC/AMP device tree overlay"
	default ""
	help
	  Device tree overlay for your I2S DAC/AMP board.
	  Leave empty for HAT EEPROM auto-detection.
	  Common overlays:
	    snapdog-dacplus, snapdog-dacplusadc, snapdog-dac,
	    snapdog-amp, snapdog-amp3,
	    allo-boss-dac-pcm512x-audio, allo-digione,
	    iqaudio-dacplus, iqaudio-dac,
	    justboom-dac, justboom-digi,
	    googlevoicehat-soundcard,
	    fe-pi-audio, i-sabre-q2m,
	    max98357a, adau7002-simple
	depends on BR2_PACKAGE_CONFIGTXT
