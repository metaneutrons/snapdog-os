[Unit]
Description=Activate /data
After=boot.mount local-fs.target systemd-remount-fs.service systemd-sysusers.service resize-partitions.service
Before=mpd.service

[Service]
Type=oneshot
ExecStartPre=/opt/snapdog/bin/bootmsg "Enabling /data"
ExecStart=/opt/snapdog/bin/activate-data-partition
StandardOutput=journal

[Install]
WantedBy=multi-user.target
