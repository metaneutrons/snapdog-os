#!/bin/sh
# Initialize /data partition with default config files.
# Runs on first boot after /data is mounted.
# Symlinks from /etc → /data are already baked into the image (post-build.sh).

set -eu

DATA=/data

# Create directory structure
mkdir -p "$DATA/default"
mkdir -p "$DATA/snapdog"
mkdir -p "$DATA/wpa_supplicant"
mkdir -p "$DATA/hostapd"
mkdir -p "$DATA/dnsmasq.d"
mkdir -p "$DATA/systemd/network"
mkdir -p "$DATA/systemd/resolved.conf.d"
mkdir -p "$DATA/systemd/system/updater.timer.d"
mkdir -p "$DATA/ssh"

# Write defaults if not already present
[ -f "$DATA/default/snapdog-client" ] || echo 'SNAPDOG_CLIENT_ARGS=""' > "$DATA/default/snapdog-client"
[ -f "$DATA/snapdog-os.channel" ] || echo "stable" > "$DATA/snapdog-os.channel"
[ -f "$DATA/snapdog-os.auto-update" ] || printf 'enabled=true\ninterval=daily\ntime=03:00\n' > "$DATA/snapdog-os.auto-update"
[ -f "$DATA/hostname" ] || echo "snapdog" > "$DATA/hostname"
