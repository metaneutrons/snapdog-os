config BR2_PACKAGE_RASPI_WIFI
	bool "raspi-wifi"
	help
	  WiFi support with temporary AP for initial setup.

	# Temp-AP
	select BR2_PACKAGE_DNSMASQ
	select BR2_PACKAGE_DNSMASQ_DHCP
	select BR2_PACKAGE_HOSTAPD
	select BR2_PACKAGE_HOSTAPD_DRIVER_NL80211
	select BR2_PACKAGE_HOSTAPD_HAS_WIFI_DRIVERS
	select BR2_PACKAGE_HOSTAPD_ACS

	# WPA supplicant (client)
	select BR2_PACKAGE_WPA_SUPPLICANT
	select BR2_PACKAGE_WPA_SUPPLICANT_NL80211
	select BR2_PACKAGE_WPA_SUPPLICANT_AP_SUPPORT
	select BR2_PACKAGE_WPA_SUPPLICANT_AUTOSCAN
	select BR2_PACKAGE_WPA_SUPPLICANT_HOTSPOT
	select BR2_PACKAGE_WPA_SUPPLICANT_DEBUG_SYSLOG
	select BR2_PACKAGE_WPA_SUPPLICANT_CLI
	select BR2_PACKAGE_WPA_SUPPLICANT_PASSPHRASE
	select BR2_PACKAGE_WPA_SUPPLICANT_DBUS
	select BR2_PACKAGE_WPA_SUPPLICANT_WPA3

	# Firmware
	select BR2_PACKAGE_BRCMFMAC_SDIO_FIRMWARE_RPI
	select BR2_PACKAGE_BRCMFMAC_SDIO_FIRMWARE_RPI_WIFI
