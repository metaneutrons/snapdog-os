#!/bin/sh
# Boot guard: automatic rollback if system fails to boot successfully.
#
# Flow:
# 1. OTA update writes "3" to /boot/boot-attempts
# 2. Each boot decrements the counter
# 3. If snapdog-ctrl starts successfully, it removes the file (marks boot OK)
# 4. If counter reaches 0, we rollback to the previous partition

ATTEMPTS_FILE=/boot/boot-attempts

if [ ! -f "$ATTEMPTS_FILE" ]; then
  # No pending update verification — normal boot
  exit 0
fi

ATTEMPTS=$(cat "$ATTEMPTS_FILE")
echo "Boot guard: $ATTEMPTS attempts remaining"

if [ "$ATTEMPTS" -le 0 ]; then
  echo "Boot guard: MAX ATTEMPTS REACHED — rolling back to previous version"
  mount -o remount,rw /boot
  /opt/snapdog/bin/reactivate-previous-release
  rm "$ATTEMPTS_FILE"
  sync
  reboot
  exit 0
fi

# Decrement counter
mount -o remount,rw /boot
echo $((ATTEMPTS - 1)) > "$ATTEMPTS_FILE"
sync
