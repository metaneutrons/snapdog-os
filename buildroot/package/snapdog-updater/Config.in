config BR2_PACKAGE_SNAPDOG_UPDATER
	bool "snapdog-updater"
	help
	  OTA update tools for SnapDog OS (dual-partition A/B).
	depends on BR2_PACKAGE_RPI_FIRMWARE
	depends on BR2_PACKAGE_SNAPDOG_BASE
	select BR2_PACKAGE_E2FSPROGS
	select BR2_PACKAGE_E2FSPROGS_RESIZE2FS
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBCURL_CURL
	select BR2_PACKAGE_PARTED
